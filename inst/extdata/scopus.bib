	author = {Chisty, Nurun Nahar and Guttin, Talia and Irin, Nusrat and Al Sattar, Abdullah and Hoque, Md. Ahasanul and Baillie, Sarah},
	title = {Utilizing Stakeholder Consultations to Identify Context-Specific Professional Skills for Veterinary Graduates in Bangladesh},
	year = {2024},
	journal = {Journal of Veterinary Medical Education},
	volume = {51},
	number = {6},
	pages = {807 – 818},
	doi = {10.3138/jvme-2023-0101},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85213596639&doi=10.3138%2fjvme-2023-0101&partnerID=40&md5=534d1652eb8518007b3f61b153c17f9a},
	affiliations = {Department of Medicine and Surgery, Chattogram Veterinary and Animal Sciences University, Zakir Hossain Road, Khulshi, Chattogram, 4225, Bangladesh; St. George's University, School of Veterinary Medicine, True Blue, West Indies, Grenada; UKRI GCRF One Health Poultry Hub, Chattogram Veterinary and Animal Sciences University, Bangladesh; Bristol Veterinary School, University of Bristol, Langford House, Langford, Bristol, BS40 5DU, United Kingdom},
	abstract = {Despite professional skills being part of the Day One Competences published by national as well as international accreditation bodies, veterinary schools in Bangladesh have limited associated teaching within their curricula. Therefore, our study aimed to identify the most important professional skills for veterinarians in Bangladesh through local consultation to inform future initiatives to change the curriculum. Eleven focus groups were conducted with 45 stakeholders who included veterinarians who supervise students on workplacements, faculty, recent graduates, final year students, and clients. The audio recordings were transcribed, translated into English from Bengali and analyzed using an inductive thematic approach. Professional skills were considered essential by all stakeholder groups. The most important professional skills were identified as communication, ethical conduct, teamwork, career options, financial management skills, lifelong learning, time management and self-appraisal. One of the best opportunities to practice many of the skills was identified as being during final year workplacements, while participating in extracurricular activities, learning by observing others and self-motivation were also considered valuable. Participants identified a need for more formal professional skills teaching within the curriculum. Challenges included finding space in the curriculum, raising awareness amongst university academics and engaging students and faculty in the new initiatives. This study has identified the most important professional skills in our context. Consultation with relevant regional stakeholders was crucial and will inform curricular change. The results are being used in the development of professional skills courses with the long-term aim of better preparing our graduates for their future careers.  © American Association of Veterinary Medical Colleges, 2024.},
	author_keywords = {communication skills; professionalism; veterinary curriculum; veterinary non-technical competencies; veterinary professional skills},
	keywords = {Bangladesh; Curriculum; Education, Veterinary; Female; Focus Groups; Humans; Male; Professional Competence; Veterinarians; accreditation; article; audio recording; awareness; Bangladesh; career; communication skill; consultation; curriculum; diagnosis; epidemiology; female; graduate; human; interpersonal communication; learning; lifelong learning; medical school; motivation; pharmacoeconomics; professionalism; self evaluation; skill; teaching; teamwork; therapy; time management; veterinarian; veterinary medicine; Bangladesh; curriculum; information processing; male; professional competence; veterinary education},
