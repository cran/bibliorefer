	year = {2024},
	journal = {Discover Mental Health},
	volume = {4},
	number = {1},
	doi = {10.1007/s44192-024-00109-x},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85209777275&doi=10.1007%2fs44192-024-00109-x&partnerID=40&md5=33a723663f2c8297f11db5ad05abde50},
	affiliations = {Department of Physiotherapy and Rehabilitation, Faculty of Health Sciences, Afyonkarahisar Health Sciences University, Zafer Saglik Kulliyesi, 2078th Street, No.: 3, Afyonkarahisar, Turkey; Terapilates Sports and Wellness Centre, Ankara, Turkey; Department of Physiotherapy and Rehabilitation, Memorial Hospital, Ankara, Turkey},
	abstract = {This study examined the relationship between physical activity (PA) level, free time management, mental well-being, and perceptions of barriers to PA among university students. A cross-sectional survey was conducted with 723 Turkish university students, which included four questionnaires to assess participants’ PA levels, conditions of mental well-being, free time management, and perceived barriers to PA. Multivariate linear regression was performed to identify factors associated with the participants’ PA level. The study found that 216 (29.9%) of participants were inactive, 325 (45%) were minimally active, and 182 (25.1%) were health-enhancing active. While 25.23% of males were inactive, 42.02% were minimally active, and 31.45% were health-enhancing active, these rates were 31.4, 45.98, and 22.62% for females, respectively. These findings highlight that 3/4 of university students have inadequate PA levels. Changes in barriers to PA (p < 0.001), free time management (p = 0.040), and mental well-being (p < 0.001) were associated with PA levels. According to the regression analysis, only increased barriers to PA was a significant predictor of PA (p < 0.001). Given the role of health science students in public health, this study could help policymakers develop new strategies to promote healthy living and address barriers to PA, such as students' free time and mental health. © The Author(s) 2024.},
	author_keywords = {Leisure; Mental health; Physical activity; University students},
	keywords = {adult; article; cross-sectional study; female; human; leisure; male; mental health; normal human; perception; physical activity; psychological well-being; questionnaire; time management; university student},
	correspondence_address = {Y.E. Kundakcı; Department of Physiotherapy and Rehabilitation, Faculty of Health Sciences, Afyonkarahisar Health Sciences University, Afyonkarahisar, Zafer Saglik Kulliyesi, 2078th Street, No.: 3, Turkey; email: y.emre.kndkc@gmail.com},
